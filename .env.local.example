# ============================================
# CityAtlas Frontend — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and must NEVER be committed.

# Browser API base URL
# Recommended for Vercel and local parity: keep this as /api/backend and use BACKEND_API_URL for upstream target.
NEXT_PUBLIC_API_URL=/api/backend

# Upstream backend API URL used by Next.js route handler (server-side)
# Development: http://localhost:8080/api
# Production:  https://your-backend-domain.com/api
BACKEND_API_URL=http://localhost:8080/api

# Public app URL (used for OG image resolution, sitemaps, etc.)
# Development: http://localhost:3000
# Production:  https://your-frontend-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
