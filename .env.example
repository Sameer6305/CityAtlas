# FIXED: Unified environment template replacing committed secrets and documenting required keys.

# Backend database
DB_URL=jdbc:postgresql://db-host:5432/cityatlas
DB_USERNAME=CHANGE_ME_DB_USERNAME
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# External APIs
OPENWEATHER_API_KEY=YOUR_API_KEY_HERE
OPENAQ_API_KEY=YOUR_API_KEY_HERE
SPOTIFY_CLIENT_ID=YOUR_API_KEY_HERE
SPOTIFY_CLIENT_SECRET=YOUR_API_KEY_HERE
SPOTIFY_REDIRECT_URI=https://api.cityatlas.example.com/api/callback/spotify
UNSPLASH_ACCESS_KEY=YOUR_API_KEY_HERE
UNSPLASH_SECRET_KEY=YOUR_API_KEY_HERE
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENAQ_BASE_URL=https://api.openaq.org/v3

# JWT auth
JWT_SECRET=CHANGE_ME_TO_A_STRONG_32_CHAR_MIN_SECRET
JWT_EXPIRATION_MS=86400000

# Demo login credentials
CITYATLAS_DEMO_EMAIL=YOUR_DEMO_LOGIN_EMAIL
CITYATLAS_DEMO_PASSWORD=YOUR_DEMO_LOGIN_PASSWORD

# CORS
CITYATLAS_CORS_ALLOWED_ORIGINS=https://cityatlas.example.com

# Optional Kafka auth/bootstrap
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=/api/backend
BACKEND_API_URL=https://api.cityatlas.example.com/api
NEXT_PUBLIC_APP_URL=https://cityatlas.example.com
