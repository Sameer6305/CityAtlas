# FIXED: Unified environment template replacing committed secrets and documenting required keys.

# Backend database
DB_URL=jdbc:postgresql://localhost:5434/cityatlas
DB_USERNAME=postgres
DB_PASSWORD=postgres

# External APIs
OPENWEATHER_API_KEY=YOUR_API_KEY_HERE
OPENAQ_API_KEY=YOUR_API_KEY_HERE
SPOTIFY_CLIENT_ID=YOUR_API_KEY_HERE
SPOTIFY_CLIENT_SECRET=YOUR_API_KEY_HERE
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/callback/spotify
UNSPLASH_ACCESS_KEY=YOUR_API_KEY_HERE
UNSPLASH_SECRET_KEY=YOUR_API_KEY_HERE
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENAQ_BASE_URL=https://api.openaq.org/v3

# JWT auth
JWT_SECRET=CHANGE_ME_TO_A_STRONG_32_CHAR_MIN_SECRET
JWT_EXPIRATION_MS=86400000

# Demo login credentials
CITYATLAS_DEMO_EMAIL=demo@example.com
CITYATLAS_DEMO_PASSWORD=hidden-for-security

# CORS
CITYATLAS_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional Kafka auth/bootstrap
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_USERNAME=
KAFKA_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
